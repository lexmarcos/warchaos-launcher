{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WarChaosDirect",
  "version": "1.0.0",
  "identifier": "com.warchaos.direct",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WarChaos Direct",
        "width": 780,
        "height": 500,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
